# Scaramuzzo Manager — esempio variabili d'ambiente
# Copia questo file in `.env.local` e compila i valori reali.
# NON inserire segreti reali in questo file e NON committare `.env.local`.

# --- Supabase (obbligatorie) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App Mobile / Team (login staff) ---
# Obbligatoria: senza, il login mobile risponde 503.
MOBILE_JWT_SECRET=

# --- Print Bridge / Fiscale ---
PRINT_BRIDGE_HEALTH_URL=
FISCAL_BRIDGE_CALLBACK_SECRET=
# Opzionale: se assente usa SUPABASE_SERVICE_ROLE_KEY come fallback.
BRIDGE_TOKEN_HASH_SECRET=

# --- Cron (reminder appuntamenti) ---
CRON_SECRET=

# --- WhatsApp (Meta Graph API) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Opzionale: default v21.0
WHATSAPP_GRAPH_API_VERSION=v21.0
WHATSAPP_OTP_TEMPLATE_NAME=
# Opzionale: default it
WHATSAPP_OTP_TEMPLATE_LANG=it
WHATSAPP_APPOINTMENT_REMINDER_TEMPLATE_NAME=
WHATSAPP_APPOINTMENT_REMINDER_TEMPLATE_LANG=it

# --- Customer Claim (collegamento account cliente) ---
# Obbligatoria in produzione (non lasciare placeholder dev).
CUSTOMER_CLAIM_OTP_PEPPER=
# Opzionali (flag "true"/"false")
CUSTOMER_CLAIM_ALLOW_CODE_MANUAL=false
CUSTOMER_CLAIM_WHATSAPP_ALLOW_SKIP=false
CUSTOMER_CLAIM_WHATSAPP_REQUIRED=false
CUSTOMER_CLAIM_DEBUG_OTP=false

# --- AI / OpenAI (OPZIONALE) ---
# Abilita le feature AI (Marketing "Migliora messaggio" + Client Intelligence AI).
# Se OPENAI_API_KEY è assente o vuota:
#   - Marketing AI resta disattivato (bottone "Migliora messaggio" disabilitato);
#   - Client Intelligence AI usa il fallback deterministico (buildClientInsights);
#   - nessuna chiamata a OpenAI viene eseguita.
OPENAI_API_KEY=
# Opzionale: modello usato dalle feature AI. Default consigliato: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
